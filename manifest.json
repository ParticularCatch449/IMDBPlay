{
  "manifest_version": 3,
  "name": "IMDBPlay",
  "version": "1.5.18",
  "description": "Play movies and series from IMDb in a lightbox player via PlayIMDB, with built-in ad blocking.",
  "action": {
    "default_popup": "popup.html",
    "default_title": "IMDBPlay"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "permissions": ["declarativeNetRequest", "tabs"],
  "background": {
    "service_worker": "background.js"
  },
  "declarative_net_request": {
    "rule_resources": [
      {
        "id": "imdb_ads",
        "enabled": true,
        "path": "rules/imdb-ads.json"
      },
      {
        "id": "player_ads",
        "enabled": true,
        "path": "rules/player-ads.json"
      }
    ]
  },
  "content_scripts": [
    {
      "matches": ["https://www.imdb.com/*", "https://m.imdb.com/*"],
      "js": ["imdb-adblock.js"],
      "css": ["imdb-adblock.css"],
      "run_at": "document_start",
      "all_frames": true
    },
    {
      "matches": ["https://www.imdb.com/*", "https://m.imdb.com/*"],
      "js": ["content.js"],
      "css": ["content.css"],
      "run_at": "document_idle"
    },
    {
      "matches": [
        "https://playimdb.com/*",
        "https://*.playimdb.com/*",
        "https://www.playimdb.com/*",
        "http://playimdb.com/*",
        "http://*.playimdb.com/*",
        "http://www.playimdb.com/*",
        "https://streamimdb.ru/*",
        "https://*.streamimdb.ru/*",
        "http://streamimdb.ru/*",
        "http://*.streamimdb.ru/*",
        "https://nextgencloudfabric.com/*",
        "https://*.nextgencloudfabric.com/*",
        "http://nextgencloudfabric.com/*",
        "http://*.nextgencloudfabric.com/*"
      ],
      "js": ["player-guard.js"],
      "run_at": "document_start",
      "all_frames": true
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["player-guard-page.js"],
      "matches": [
        "https://playimdb.com/*",
        "https://*.playimdb.com/*",
        "https://www.playimdb.com/*",
        "http://playimdb.com/*",
        "http://*.playimdb.com/*",
        "http://www.playimdb.com/*",
        "https://streamimdb.ru/*",
        "https://*.streamimdb.ru/*",
        "http://streamimdb.ru/*",
        "http://*.streamimdb.ru/*",
        "https://nextgencloudfabric.com/*",
        "https://*.nextgencloudfabric.com/*",
        "http://nextgencloudfabric.com/*",
        "http://*.nextgencloudfabric.com/*"
      ]
    }
  ],
  "host_permissions": [
    "https://playimdb.com/*",
    "https://*.playimdb.com/*",
    "https://www.playimdb.com/*",
    "http://playimdb.com/*",
    "http://*.playimdb.com/*",
    "http://www.playimdb.com/*",
    "https://streamimdb.ru/*",
    "https://*.streamimdb.ru/*",
    "http://streamimdb.ru/*",
    "http://*.streamimdb.ru/*",
    "https://nextgencloudfabric.com/*",
    "https://*.nextgencloudfabric.com/*",
    "http://nextgencloudfabric.com/*",
    "http://*.nextgencloudfabric.com/*",
    "https://v3.sg.media-imdb.com/*"
  ]
}
